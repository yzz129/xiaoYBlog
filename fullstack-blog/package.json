{
    "name": "vue3-ts-blog-frontend",
    "version": "2.7.14",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "build:analyze": "cross-env npm_config_report=true npm run build",
        "test:unit": "jest",
        "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
        "postinstall": "husky install",
        "prepare": "husky install",
        "create-release": "release-it --ci",
        "sync-remote-tags": "git tag -l | xargs git tag -d && git pull --tags"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cumt-robin/vue3-ts-blog-frontend.git"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/cumt-robin/vue3-ts-blog-frontend/issues"
    },
    "homepage": "https://blog.wbjiang.cn/",
    "dependencies": {
        "ant-design-vue": "^4.2.5",
        "axios": "^1.6.5",
        "bezier-easing": "^2.1.0",
        "dayjs": "^1.11.10",
        "dompurify": "^3.0.8",
        "element-plus": "^2.5.6",
        "highlight.js": "^11.9.0",
        "js-cookie": "^3.0.5",
        "jshashes": "^1.0.8",
        "lodash-es": "^4.17.21",
        "mammoth": "^1.12.0",
        "marked": "^11.1.1",
        "mitt": "^3.0.1",
        "pdfjs-dist": "^5.5.207",
        "pinia": "^2.1.7",
        "qs": "^6.11.2",
        "socket.io-client": "^4.7.4",
        "vue": "^3.4.21",
        "vue-router": "^4.2.5"
    },
    "devDependencies": {
        "@commitlint/cli": "^18.6.0",
        "@commitlint/config-conventional": "^18.6.0",
        "@release-it/conventional-changelog": "7.0.2",
        "@types/dompurify": "^3.0.5",
        "@types/jest": "^29.5.12",
        "@types/js-cookie": "^3.0.6",
        "@types/lodash-es": "^4.17.12",
        "@types/marked": "^5.0.1",
        "@types/qs": "^6.15.0",
        "@types/webpack-env": "^1.18.8",
        "@typescript-eslint/eslint-plugin": "^6.21.0",
        "@typescript-eslint/parser": "^6.21.0",
        "@vitejs/plugin-vue": "^5.0.4",
        "@vue/eslint-config-prettier": "^8.0.0",
        "@vue/eslint-config-typescript": "^12.0.0",
        "@vue/test-utils": "^2.4.5",
        "babel-plugin-import": "^1.13.3",
        "cross-env": "^7.0.3",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^8.56.0",
        "eslint-import-resolver-typescript": "^3.6.1",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-prettier": "^5.1.3",
        "eslint-plugin-vue": "^9.21.1",
        "husky": "^8.0.3",
        "jest": "^29.7.0",
        "less": "^4.2.0",
        "lint-staged": "^15.2.2",
        "prettier": "^3.2.5",
        "release-it": "16.3.0",
        "sass": "^1.70.0",
        "stylelint": "^16.2.1",
        "stylelint-config-prettier": "^9.0.5",
        "stylelint-config-standard": "^36.0.0",
        "stylelint-prettier": "^4.1.0",
        "stylelint-scss": "^5.3.2",
        "typescript": "^5.3.3",
        "vite": "^5.1.4",
        "vite-plugin-compression": "^0.5.1",
        "vue-jest": "^5.0.0-alpha.10",
        "vue-tsc": "^1.8.27",
        "webpack-bundle-analyzer": "^4.10.1"
    },
    "lint-staged": {
        "*.{js,jsx,vue,ts,tsx}": [
            "npm run lint",
            "git add"
        ]
    },
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-conventional-changelog"
        }
    },
    "engines": {
        "node": ">=20.0.0"
    }
}

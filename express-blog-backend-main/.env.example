NODE_ENV=development
PORT=8002

ALLOW_CLIENT=localhost:3000,127.0.0.1:3000,localhost:8080,127.0.0.1:8080

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=blog
MYSQL_MULTIPLE_STATEMENTS=true
MYSQL_WAIT_FOR_CONNECTIONS=true
MYSQL_CHARSET=UTF8MB4_UNICODE_CI

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CONNECT_TIMEOUT_MS=2000
REDIS_RETRY_AFTER_MS=30000

JWT_SECRET=blog-secret-key
JWT_EXPIRE_DAYS=3
AUTH_COOKIE_NAME=blog_token
AUTH_CSRF_COOKIE_NAME=blog_csrf
AUTH_COOKIE_SAMESITE=Lax
AUTH_COOKIE_SECURE=false

EMAIL_SERVICE=163
EMAIL_PORT=465
EMAIL_SECURE_CONNECTION=true
EMAIL_AUTH_USER=
EMAIL_AUTH_PASS=
AUTHOR_EMAIL=
BLOG_NAME=小Y 博客
SITE_URL=
OPENAI_API_KEY=

BAIDU_API_KEY=
DEEPSEEK_API_KEY=
TAVILY_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
AI_KNOWLEDGE_CUTOFF=2024-12
AI_SESSION_TTL_SECONDS=21600
AI_REQUEST_TIMEOUT_MS=45000

MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=blog-assets
MINIO_REGION=us-east-1
MINIO_PUBLIC_BASE_URL=http://127.0.0.1:9000

    "dependencies": {
        "@langchain/community": "^1.1.22",
        "@langchain/core": "^1.1.31",
        "@langchain/openai": "^1.2.12",
        "compression": "^1.7.4",
        "cookie-parser": "^1.4.6",
        "debug": "^4.3.4",
        "dotenv": "^17.3.1",
        "ejs": "^3.1.9",
        "express": "^4.18.2",
        "express-session": "^1.17.3",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "langchain": "^1.2.30",
        "lodash": "^4.17.21",
        "minio": "^8.0.7",
        "morgan": "^1.10.0",
